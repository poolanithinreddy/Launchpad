{
  "name": "@launchpad/db",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "dev": "pnpm run prisma:generate && tsc -w -p tsconfig.json --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "dotenv -e ../../apps/server/.env -- prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "dotenv -e ../../apps/server/.env -- prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "dotenv -e ../../apps/server/.env -- prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.0.0"
  }
}
